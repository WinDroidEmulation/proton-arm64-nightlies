 static struct list acquired_device_list = LIST_INIT( acquired_device_list );
 
+#ifdef __ANDROID__
+static BOOL android_dinput_compat_enabled(void)
+{
+    return getenv( "WINE_ANDROID_DINPUT_COMPAT" ) != NULL;
+}
+
+static void dinput_android_compat_fanout_rawinput( RAWINPUT *ri, WPARAM wparam, LPARAM lparam )
+{
+    struct dinput_device *device, *targets[16];
+    UINT count = 0, i;
+
+    if (!android_dinput_compat_enabled()) return;
+
+    EnterCriticalSection( &dinput_hook_crit );
+    LIST_FOR_EACH_ENTRY( device, &acquired_device_list, struct dinput_device, entry )
+    {
+        if (device->status != STATUS_ACQUIRED) continue;
+        if (device->use_raw_input) continue;
+        if (device->instance.dwDevType & DIDEVTYPE_HID) continue;
+
+        switch (GET_DIDEVICE_TYPE( device->instance.dwDevType ))
+        {
+        case DIDEVTYPE_MOUSE:
+        case DI8DEVTYPE_MOUSE:
+            if (ri->header.dwType != RIM_TYPEMOUSE) continue;
+            break;
+        case DIDEVTYPE_KEYBOARD:
+        case DI8DEVTYPE_KEYBOARD:
+            if (ri->header.dwType != RIM_TYPEKEYBOARD) continue;
+            break;
+        default:
+            continue;
+        }
+
+        dinput_device_internal_addref( device );
+        targets[count++] = device;
+        if (count >= ARRAY_SIZE( targets )) break;
+    }
+    LeaveCriticalSection( &dinput_hook_crit );
+
+    for (i = 0; i < count; ++i)
+    {
+        device = targets[i];
+        switch (GET_DIDEVICE_TYPE( device->instance.dwDevType ))
+        {
+        case DIDEVTYPE_MOUSE:
+        case DI8DEVTYPE_MOUSE:
+            dinput_mouse_rawinput_hook( &device->IDirectInputDevice8W_iface, wparam, lparam, ri );
+            break;
+        case DIDEVTYPE_KEYBOARD:
+        case DI8DEVTYPE_KEYBOARD:
+            dinput_keyboard_rawinput_hook( &device->IDirectInputDevice8W_iface, wparam, lparam, ri );
+            break;
+        }
+        dinput_device_internal_release( device );
+    }
+}
+#endif
